# Copy this file to ~/.llama-metrics/.env for normal use, or to ./.env for
# development inside a checkout.
#
# Existing llama-server base URL. LlamaMetrics observes this server; it does
# not start or manage inference.
LLAMA_BASE_URL=http://127.0.0.1:8080

# Optional llama-server Bearer token. If llama-server is protected, set this to
# the same token that llama-server expects. This stays backend-only and is never
# sent to the browser.
LLAMA_API_KEY=

# Optional model query value for llama-server router-style /metrics setups.
LLAMA_METRICS_MODEL=

# 0 = real monitoring mode.
# 1 = demo mode with generated mock telemetry; does not require llama-server,
#     NVIDIA GPU hardware, or NVML.
LLAMA_METRICS_DEMO=0

# Dashboard bind address. 0.0.0.0 exposes the dashboard on reachable interfaces.
OBSERVER_HOST=0.0.0.0
OBSERVER_PORT=7778

POLL_INTERVAL_SECONDS=1
HISTORY_RETENTION_MINUTES=30

GPU_TEMPERATURE_ALERT_C=85
GPU_VRAM_ALERT_PERCENT=90
GENERATION_THROUGHPUT_DROP_PERCENT=40
GENERATION_THROUGHPUT_DROP_WINDOW_SECONDS=30
